    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.13",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "gulp": "^5.0.0",
    "gulp-zip": "^6.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.3",
